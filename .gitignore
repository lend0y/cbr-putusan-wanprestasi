# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Raw PDFs — terlalu besar untuk Git, simpan di Drive saja
data/raw/pdf/*.pdf
data/raw/html/*.html

# Output ekstraksi yang regenerable
data/raw/text/*.txt
data/cleaned/*.txt

# Logs (regenerable)
logs/*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Local secrets
.env
*.key

# Folder legacy
dokumen/

# Pastikan .gitkeep tetap ke-track meski folder isinya di-ignore
!**/.gitkeep
